# ============================================
# DAB Enterprise Ltd - Inventory & Sales Management System
# Backend Environment Configuration Template
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=inventory_sales_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update DB_PASSWORD with your MySQL root password
# 3. Change JWT_SECRET to a strong random string
# 4. Run database setup: mysql -u root -p < setup.sql
# 5. Start backend: npm start
# ============================================
